# RoachFlix environment variables — copy to .env and fill in values
SECRET_KEY=change-this-to-a-random-secret-key

# TMDB — get a free API key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Telegram — bot token only; chat ID and thread are set in telegram_config.py
TELEGRAM_BOT_TOKEN=

# Google Calendar — paste the full JSON from your OAuth2 credentials file
GOOGLE_CALENDAR_CREDENTIALS_JSON=

# Initial family passwords (used by seed_users.py, not needed at runtime)
PASSWORD_HOMIE=changeme
PASSWORD_GILLIAN=changeme
PASSWORD_LOREN=changeme
PASSWORD_BLYTHE=changeme
